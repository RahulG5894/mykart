# Copy to .env and fill in values:  cp .env.example .env
#
# Local run:  .\gradlew.bat bootRun   (uses DB_HOST=localhost from .env)
# Compose:     docker compose up --build   (compose overrides DB_HOST to postgres)
# Docker only: docker run --env-file .env -e DB_HOST=host.docker.internal -p 8089:8089 mykart-be

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Test
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Mail (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Server
SERVER_PORT=8089
SERVER_SERVLET_CONTEXT_PATH=/kart-service
